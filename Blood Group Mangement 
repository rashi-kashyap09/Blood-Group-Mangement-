
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// structure for donor
struct d {
    int id;
    char name[20];
    char blood[5];
    int age;
    struct d *next;
};

struct d *start = NULL; // head pointer

int a=0,b=0,o=0,ab=0;  // blood stock counters

// check if blood group is valid
int checkGroup(char g[]) {
    if(strcmp(g,"A")==0 || strcmp(g,"a")==0) return 1;
    if(strcmp(g,"B")==0 || strcmp(g,"b")==0) return 1;
    if(strcmp(g,"O")==0 || strcmp(g,"o")==0) return 1;
    if(strcmp(g,"AB")==0 || strcmp(g,"ab")==0) return 1;
    return 0;
}

// update stock counts
void updateStock() {
    struct d *temp = start;

    a=0; b=0; o=0; ab=0;

    while(temp!=NULL) {
        if(strcmp(temp->blood,"A")==0 || strcmp(temp->blood,"a")==0) a++;
        else if(strcmp(temp->blood,"B")==0 || strcmp(temp->blood,"b")==0) b++;
        else if(strcmp(temp->blood,"O")==0 || strcmp(temp->blood,"o")==0) o++;
        else if(strcmp(temp->blood,"AB")==0 || strcmp(temp->blood,"ab")==0) ab++;
        temp = temp->next;
    }
}

// save data to file
void saveData() {
    FILE *fp = fopen("blood.txt","w");
    if(fp == NULL) {
        printf("Error opening file for writing.\n");
        return;
    }

    struct d *temp = start;

    while(temp != NULL) {
        fprintf(fp,"%d %s %s %d\n", temp->id, temp->name, temp->blood, temp->age);
        temp = temp->next;
    }

    fclose(fp);
}

// load data from file
void loadData() {
    FILE *fp = fopen("blood.txt","r");
    if(fp==NULL) return;  // no file yet, safe

    struct d *newNode, *temp;

    while(1) {
        newNode = (struct d*)malloc(sizeof(struct d));
        if(newNode == NULL) {
            printf("Memory allocation failed!\n");
            break;
        }

        if(fscanf(fp,"%d %19s %4s %d",&newNode->id,newNode->name,newNode->blood,&newNode->age)!=4) {
            free(newNode);
            break;   // stop if reading fails
        }

        newNode->next = NULL;

        if(start==NULL) start = newNode;
        else {
            temp = start;
            while(temp->next != NULL) temp = temp->next;
            temp->next = newNode;
        }
    }

    fclose(fp);
    updateStock();
}

// add donor
void addDonor() {
    struct d *newNode, *temp;

    newNode = (struct d*)malloc(sizeof(struct d));
    if(newNode == NULL) {
        printf("Memory allocation failed!\n");
        return;
    }

    printf("Enter ID: ");
    scanf("%d",&newNode->id);

    printf("Enter Name: ");
    scanf("%19s",newNode->name);

    printf("Enter Blood Group (A/B/O/AB): ");
    scanf("%4s",newNode->blood);

    if(!checkGroup(newNode->blood)) {
        printf("Invalid blood group!\n");
        free(newNode);
        return;
    }

    printf("Enter Age: ");
    scanf("%d",&newNode->age);

    if(newNode->age < 18) {
        printf("Sorry, donor must be 18 or above.\n");
        free(newNode);
        return;
    }

    newNode->next = NULL;

    if(start==NULL) start = newNode;
    else {
        temp = start;
        while(temp->next != NULL) temp = temp->next;
        temp->next = newNode;
    }

    updateStock();
    saveData();

    printf("Donor added successfully!\n");
}

// show all donors
void showDonors() {
    struct d *temp = start;

    if(temp==NULL) {
        printf("No donor data available.\n");
        return;
    }

    printf("ID Name Blood Age\n");
    while(temp!=NULL) {
        printf("%d %s %s %d\n",temp->id,temp->name,temp->blood,temp->age);
        temp = temp->next;
    }
}

// search donor by blood group
void searchDonor() {
    char g[5];
    int found = 0;

    if(start==NULL) {
        printf("No donors available.\n");
        return;
    }

    printf("Enter Blood Group to search: ");
    scanf("%4s",g);

    struct d *temp = start;

    while(temp!=NULL) {
        if(strcmp(temp->blood,g)==0) {
            printf("%d %s %s %d\n",temp->id,temp->name,temp->blood,temp->age);
            found = 1;
        }
        temp = temp->next;
    }

    if(!found) printf("No donor found for this blood group.\n");
}

// delete donor by ID
void deleteDonor() {
    if(start==NULL) {
        printf("No donors to delete.\n");
        return;
    }

    int id;
    printf("Enter ID to delete: ");
    scanf("%d",&id);

    struct d *temp=start, *prev=NULL;

    while(temp!=NULL && temp->id!=id) {
        prev=temp;
        temp=temp->next;
    }

    if(temp==NULL) {
        printf("ID not found.\n");
        return;
    }

    if(prev==NULL) start=temp->next;
    else prev->next = temp->next;

    free(temp);
    updateStock();
    saveData();

    printf("Donor deleted successfully.\n");
}

// update donor by ID
void updateDonor() {
    if(start==NULL) {
        printf("No donors to update.\n");
        return;
    }

    int id;
    printf("Enter ID to update: ");
    scanf("%d",&id);

    struct d *temp=start;

    while(temp!=NULL && temp->id!=id) temp=temp->next;

    if(temp==NULL) {
        printf("ID not found.\n");
        return;
    }

    printf("Enter new Name: ");
    scanf("%19s",temp->name);

    printf("Enter new Blood Group: ");
    scanf("%4s",temp->blood);
    if(!checkGroup(temp->blood)) {
        printf("Invalid blood group!\n");
        return;
    }

    printf("Enter new Age: ");
    scanf("%d",&temp->age);

    updateStock();
    saveData();

    printf("Donor updated successfully.\n");
}

// show blood stock
void showStock() {
    printf("Blood Stock: A=%d B=%d O=%d AB=%d\n",a,b,o,ab);
}


int main() {
    int choice;

    loadData();

    while(1) {
        printf("\n--- Blood Bank Menu ---\n");
        printf("1. Add Donor\n2. Show All Donors\n3. Search Donor\n4. Delete Donor\n5. Update Donor\n6. Show Blood Stock\n7. Exit\n");
        printf("Enter your choice: ");
        scanf("%d",&choice);

        if(choice==1) addDonor();
        else if(choice==2) showDonors();
        else if(choice==3) searchDonor();
        else if(choice==4) deleteDonor();
        else if(choice==5) updateDonor();
        else if(choice==6) showStock();
        else if(choice==7) {
            saveData();
            printf("Exiting program. Goodbye!\n");
            break;
        }
        else printf("Invalid choice! Try again.\n");
    }

    return 0;
}